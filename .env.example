NEXT_PUBLIC_SUPABASE_URL=       # Supabase → Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=  # Supabase → Project Settings → API → anon/public
SUPABASE_SERVICE_ROLE_KEY=      # Supabase → Project Settings → API → service_role (server only)
ANTHROPIC_API_KEY=              # console.anthropic.com → API Keys (server only)
UPSTASH_REDIS_REST_URL=         # console.upstash.com → Redis DB → REST API URL
UPSTASH_REDIS_REST_TOKEN=       # console.upstash.com → Redis DB → REST API token
NEXT_PUBLIC_APP_URL=            # http://localhost:3000 locally; Vercel URL in production
FAL_KEY=                        # fal.ai → Dashboard → API Keys (server only)
FIRECRAWL_API_KEY=              # firecrawl.dev → Dashboard → API Keys (server only)
SUPADATA_API_KEY=               # supadata.ai → Dashboard → API Keys (server only)
PADDLE_API_KEY=                # Paddle → Developer Tools → API Keys (server only)
PADDLE_WEBHOOK_SECRET=         # Paddle → Notifications → Webhook destination → Secret key (server only)
PADDLE_ENV=                    # "sandbox" or "production"
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN= # Paddle → Developer Tools → Client-side token
RESEND_API_KEY=                # resend.com → API Keys (server only)
ADMIN_NOTIFICATION_EMAIL=      # Your email address for signup notifications
NEXT_PUBLIC_GA_MEASUREMENT_ID= # Google Analytics 4 → Admin → Data Streams → Measurement ID (G-XXXXXXXXXX)
NEXT_PUBLIC_REDDIT_PIXEL_ID=   # Reddit Ads → Events Manager → Pixel ID (t2_XXXXXXXX)
NEXT_PUBLIC_HOTJAR_ID=         # Hotjar → Settings → Sites & Organizations → Site ID (numeric)
